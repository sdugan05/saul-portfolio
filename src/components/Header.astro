---
const navItems = [
  { href: "/", label: "Home" },
  { href: "/projects", label: "Projects" },
  { href: "/resume", label: "Resume" },
  { href: "/#contact", label: "Contact" },
];
---

<header class="sticky top-0 z-40 border-b border-zinc-200/80 bg-white/82 backdrop-blur">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4" aria-label="Primary navigation">
    <a class="focus-ring rounded-sm text-sm font-semibold uppercase tracking-[0.18em] text-zinc-950" href="/">
      Saul Dugan
    </a>
    <div class="flex items-center gap-1 sm:gap-2">
      {
        navItems.map((item) => (
          <a
            class="focus-ring rounded-md px-2.5 py-2 text-sm text-zinc-600 transition hover:bg-blue-50 hover:text-blue-700 sm:px-3"
            href={item.href}
          >
            {item.label}
          </a>
        ))
      }
    </div>
  </nav>
</header>
