---
import type { SkillGroup } from "../data/skills";

interface Props {
  group: SkillGroup;
}

const { group } = Astro.props;
---

<section class="rounded-lg border border-zinc-200 bg-white p-5 shadow-sm">
  <h3 class="text-base font-semibold text-zinc-950">{group.title}</h3>
  <ul class="mt-4 flex flex-wrap gap-2">
    {
      group.skills.map((skill) => (
        <li class="rounded border border-zinc-200 bg-zinc-50 px-3 py-1.5 text-sm text-zinc-600">
          {skill}
        </li>
      ))
    }
  </ul>
</section>
