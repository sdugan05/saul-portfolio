---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="mb-8 max-w-3xl">
  {
    eyebrow && (
      <p class="mb-3 text-xs font-semibold uppercase tracking-[0.22em] text-blue-600">
        {eyebrow}
      </p>
    )
  }
  <h2 class="text-2xl font-semibold text-zinc-950 sm:text-3xl">{title}</h2>
  {description && <p class="mt-3 text-base leading-7 text-zinc-600">{description}</p>}
</div>
