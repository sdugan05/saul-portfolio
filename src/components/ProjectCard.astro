---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="group rounded-lg border border-zinc-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-blue-200 hover:shadow-md">
  <div class="mb-5 flex aspect-[16/9] items-center justify-center rounded-md border border-dashed border-blue-200 bg-blue-50/70 text-center text-xs font-medium uppercase tracking-[0.18em] text-blue-500">
    Screenshot TODO
  </div>
  <h3 class="text-lg font-semibold text-zinc-950">
    <a class="focus-ring rounded-sm hover:text-blue-700" href={`/projects/${project.slug}`}>
      {project.title}
    </a>
  </h3>
  <p class="mt-3 text-sm leading-6 text-zinc-600">{project.summary}</p>
  <ul class="mt-5 flex flex-wrap gap-2" aria-label={`${project.title} tags`}>
    {
      project.tags.map((tag) => (
        <li class="rounded border border-zinc-200 bg-zinc-50 px-2.5 py-1 text-xs text-zinc-600">
          {tag}
        </li>
      ))
    }
  </ul>
  <a
    class="focus-ring mt-5 inline-flex rounded-sm text-sm font-semibold text-blue-600 transition group-hover:text-blue-800"
    href={`/projects/${project.slug}`}
  >
    Read case study
  </a>
</article>
