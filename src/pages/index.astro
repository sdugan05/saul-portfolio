---
import LinkButton from "../components/LinkButton.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SectionHeading from "../components/SectionHeading.astro";
import SkillGroup from "../components/SkillGroup.astro";
import Layout from "../layouts/Layout.astro";
import { featuredProjects } from "../data/projects";
import { skillGroups } from "../data/skills";
---

<Layout
  title="Saul Dugan"
  description="Saul Dugan builds quantitative trading systems, AI-assisted research tools, and low-level software."
>
  <section class="mx-auto grid min-h-[calc(100vh-5rem)] max-w-6xl items-center gap-12 px-5 py-16 lg:grid-cols-[1.1fr_0.9fr] lg:py-20">
    <div>
      <p class="mb-5 text-sm font-semibold uppercase tracking-[0.22em] text-blue-600">
        Quant systems / AI infrastructure / low-level engineering
      </p>
      <h1 class="max-w-4xl text-4xl font-semibold leading-tight text-zinc-950 sm:text-5xl lg:text-6xl">
        Saul Dugan
      </h1>
      <p class="mt-6 max-w-3xl text-xl leading-8 text-zinc-900 sm:text-2xl">
        I build quantitative trading systems, AI-assisted research tools, and low-level software.
      </p>
      <p class="mt-5 max-w-2xl text-base leading-7 text-zinc-600">
        Focused on futures trading infrastructure, backtesting, risk controls, Palantir Foundry workflows, and systems-level engineering.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <LinkButton href="#projects" label="View Projects" />
        <LinkButton href="/resume" label="View Resume" variant="secondary" />
        <LinkButton href="#contact" label="Contact" variant="ghost" />
      </div>
    </div>

    <aside class="rounded-lg border border-zinc-200 bg-white p-5 shadow-sm" aria-label="Portfolio focus areas">
      <div class="grid gap-3">
        <div class="rounded-md border border-blue-200 bg-blue-50 p-4">
          <p class="text-xs uppercase tracking-[0.2em] text-blue-600">Current focus</p>
          <p class="mt-2 text-sm leading-6 text-zinc-700">
            Research infrastructure for strategies, validation, and operational trading workflows.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div class="rounded-md border border-zinc-200 bg-white p-4">
            <p class="text-xs text-zinc-500">Systems</p>
            <p class="mt-2 text-lg font-semibold text-zinc-950">C / C++ / C#</p>
          </div>
          <div class="rounded-md border border-zinc-200 bg-white p-4">
            <p class="text-xs text-zinc-500">Research</p>
            <p class="mt-2 text-lg font-semibold text-zinc-950">Python / AI</p>
          </div>
        </div>
        <div class="rounded-md border border-dashed border-blue-200 bg-blue-50/60 p-4">
          <p class="text-xs uppercase tracking-[0.18em] text-blue-500">Artifact placeholder</p>
          <p class="mt-2 text-sm leading-6 text-zinc-600">
            Add screenshots, repository links, research diagrams, or product demos here later.
          </p>
        </div>
      </div>
    </aside>
  </section>

  <section id="projects" class="mx-auto max-w-6xl px-5 py-16">
    <SectionHeading
      eyebrow="Featured projects"
      title="Technical work across trading systems, research tooling, and low-level software."
      description="Each card links to a case-study page with placeholders for screenshots, results, and source links."
    />
    <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {featuredProjects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="border-y border-zinc-200 bg-white/58">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <SectionHeading eyebrow="Skills" title="A practical stack for building and validating technical systems." />
      <div class="grid gap-5 md:grid-cols-2">
        {skillGroups.map((group) => <SkillGroup group={group} />)}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 py-16">
    <SectionHeading eyebrow="About" title="Builder at the intersection of markets, systems, and automation." />
    <p class="max-w-3xl text-lg leading-8 text-zinc-600">
      I’m a technical builder interested in the intersection of financial markets, software systems, AI-assisted research, and practical automation. My work focuses on turning messy real-world workflows into structured systems: ingesting data, defining models, validating decisions, and building tools that can actually be used.
    </p>
  </section>

  <section id="contact" class="mx-auto max-w-6xl px-5 pb-20">
    <div class="rounded-lg border border-zinc-200 bg-white p-6 shadow-sm sm:p-8">
      <SectionHeading eyebrow="Contact" title="Links and resume" description="Replace the TODO placeholders when your public profiles are ready." />
      <dl class="grid gap-4 text-sm sm:grid-cols-2 lg:grid-cols-4">
        <div>
          <dt class="text-zinc-500">Email</dt>
          <dd class="mt-1 font-medium text-zinc-800">TODO</dd>
        </div>
        <div>
          <dt class="text-zinc-500">GitHub</dt>
          <dd class="mt-1 font-medium text-zinc-800">TODO</dd>
        </div>
        <div>
          <dt class="text-zinc-500">LinkedIn</dt>
          <dd class="mt-1 font-medium text-zinc-800">TODO</dd>
        </div>
        <div>
          <dt class="text-zinc-500">Resume PDF</dt>
          <dd class="mt-1">
            <a class="focus-ring rounded-sm font-medium text-blue-600 hover:text-blue-800" href="/resume.pdf">
              /resume.pdf
            </a>
          </dd>
        </div>
      </dl>
    </div>
  </section>
</Layout>
