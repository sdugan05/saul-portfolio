---
import LinkButton from "../../components/LinkButton.astro";
import Layout from "../../layouts/Layout.astro";
import { projects } from "../../data/projects";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<Layout title={project.title} description={project.summary}>
  <article class="mx-auto max-w-4xl px-5 py-14 sm:py-20">
    <a class="focus-ring mb-8 inline-flex rounded-sm text-sm font-semibold text-blue-600 hover:text-blue-800" href="/projects">
      Back to projects
    </a>

    <header>
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-blue-600">Case study</p>
      <h1 class="mt-4 text-3xl font-semibold leading-tight text-zinc-950 sm:text-5xl">{project.title}</h1>
      <p class="mt-5 text-lg leading-8 text-zinc-600">{project.summary}</p>
      <ul class="mt-6 flex flex-wrap gap-2" aria-label={`${project.title} technologies`}>
        {
          project.tags.map((tag) => (
            <li class="rounded border border-zinc-200 bg-white px-3 py-1.5 text-sm text-zinc-600">
              {tag}
            </li>
          ))
        }
      </ul>
    </header>

    <div class="mt-10 rounded-lg border border-dashed border-blue-200 bg-blue-50/70 p-6 text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-blue-500">Screenshot / demo TODO</p>
      <p class="mt-3 text-sm leading-6 text-zinc-600">
        Add project screenshots, architecture diagrams, backtest reports, or repository previews here.
      </p>
    </div>

    <div class="mt-12 grid gap-8">
      <section>
        <h2 class="text-2xl font-semibold text-zinc-950">Overview</h2>
        <p class="mt-3 text-base leading-7 text-zinc-600">{project.overview}</p>
      </section>

      <section>
        <h2 class="text-2xl font-semibold text-zinc-950">Problem</h2>
        <p class="mt-3 text-base leading-7 text-zinc-600">{project.problem}</p>
      </section>

      <section>
        <h2 class="text-2xl font-semibold text-zinc-950">What I Built</h2>
        <ul class="mt-4 space-y-3 text-base leading-7 text-zinc-600">
          {project.built.map((item) => <li class="border-l border-blue-300 pl-4">{item}</li>)}
        </ul>
      </section>

      <section>
        <h2 class="text-2xl font-semibold text-zinc-950">Technologies Used</h2>
        <ul class="mt-4 flex flex-wrap gap-2">
          {
            project.technologies.map((technology) => (
              <li class="rounded border border-zinc-200 bg-white px-3 py-1.5 text-sm text-zinc-600">
                {technology}
              </li>
            ))
          }
        </ul>
      </section>

      <section>
        <h2 class="text-2xl font-semibold text-zinc-950">Key Technical Challenges</h2>
        <ul class="mt-4 space-y-3 text-base leading-7 text-zinc-600">
          {project.challenges.map((item) => <li class="border-l border-zinc-300 pl-4">{item}</li>)}
        </ul>
      </section>

      <section>
        <h2 class="text-2xl font-semibold text-zinc-950">What It Demonstrates</h2>
        <ul class="mt-4 grid gap-3 sm:grid-cols-2">
          {
            project.demonstrates.map((item) => (
              <li class="rounded-md border border-zinc-200 bg-white p-4 text-sm font-medium text-zinc-800 shadow-sm">
                {item}
              </li>
            ))
          }
        </ul>
      </section>

      <section class="rounded-lg border border-zinc-200 bg-white p-6 shadow-sm">
        <h2 class="text-2xl font-semibold text-zinc-950">TODO</h2>
        <ul class="mt-4 space-y-2 text-base leading-7 text-zinc-600">
          <li>Add screenshots or diagrams.</li>
          <li>Add repository, demo, or write-up links when they are public.</li>
          <li>Add measured results only when they can be accurately sourced.</li>
        </ul>
      </section>
    </div>

    <div class="mt-12 flex flex-wrap gap-3">
      <LinkButton href="/projects" label="All Projects" variant="secondary" />
      <LinkButton href="/#contact" label="Contact" />
    </div>
  </article>
</Layout>
