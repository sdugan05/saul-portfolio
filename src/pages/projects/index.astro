---
import ProjectCard from "../../components/ProjectCard.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import Layout from "../../layouts/Layout.astro";
import { projects } from "../../data/projects";
---

<Layout
  title="Projects"
  description="Case studies from Saul Dugan across quantitative trading systems, AI-assisted research tools, and low-level software."
>
  <section class="mx-auto max-w-6xl px-5 py-16 sm:py-20">
    <SectionHeading
      eyebrow="Projects"
      title="Case studies and technical project notes."
      description="These pages are structured so screenshots, repositories, results, and deeper implementation notes can be added without redesigning the site."
    />
    <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>
</Layout>
