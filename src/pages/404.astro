---
import LinkButton from "../components/LinkButton.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page Not Found" description="The requested page could not be found.">
  <section class="mx-auto flex min-h-[calc(100vh-12rem)] max-w-3xl flex-col justify-center px-5 py-16">
    <p class="text-sm font-semibold uppercase tracking-[0.22em] text-blue-600">404</p>
    <h1 class="mt-4 text-4xl font-semibold text-zinc-950">Page not found</h1>
    <p class="mt-4 text-base leading-7 text-zinc-600">
      This route does not exist yet. The project case studies and resume page are available from the main navigation.
    </p>
    <div class="mt-8">
      <LinkButton href="/" label="Go Home" />
    </div>
  </section>
</Layout>
